# Python cache and test artifacts
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/

# IDE and OS files
# Keep local desktop-tool clutter out of the repo by default.
# Keep workflow/debug artifacts tracked unless we explicitly decide they are local-only.
.vscode/
.idea/
.DS_Store
Thumbs.db
Desktop.ini

# Logs
*.log

# Local prompt/reference images and temporary visual inputs
ComfyUI_*.png
ComfyUI_*.jpg
ComfyUI_*.jpeg
ComfyUI_*.webp
ComfyUI_*.gif
ComfyUI_*.bmp

# Local release packaging artifacts
.release-assets/

# Prompt polishing follows tracked markdown files; expression regression uses tracked tests and workflow scripts.
# Expression history tests create temp folders only on failed/interrupted runs.
Game content extraction/_tmp_history_test_*/
Game content extraction/_tmp_history_verify_*/

# Desktop app build/release artifacts are intentionally tracked in this repo.
# Keep ignore changes scoped to untracked local clutter only.
