# Python cache and test artifacts
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/

# IDE and OS files
# Keep local desktop-tool clutter out of the repo by default.
# Keep workflow/debug artifacts tracked unless we explicitly decide they are local-only.
.vscode/
.idea/
.DS_Store
Thumbs.db
Desktop.ini

# Logs
*.log

# Desktop app build/release artifacts are intentionally tracked in this repo.
# Keep ignore changes scoped to untracked local clutter only.
